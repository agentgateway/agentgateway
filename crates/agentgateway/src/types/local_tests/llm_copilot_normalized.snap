---
source: crates/agentgateway/src/types/local_tests.rs
description: "Config normalization test for llm_copilot: YAML -> LocalConfig -> NormalizedLocalConfig -> YAML"
---
binds:
  - key: bind/4000
    address: "[::]:4000"
    protocol: http
    tunnelProtocol: direct
    listeners:
      llm:
        gatewayName: name
        gatewayNamespace: ns
        hostname: "*"
        key: llm
        listenerName: llm
        protocol: HTTP
listener_routes:
  - - llm
    - - inlinePolicies:
          - responseHeaderModifier:
              set:
                Content-Type: application/json
          - directResponse:
              body: eyJkYXRhIjpbeyJpZCI6ImdwdC01LjQiLCJvYmplY3QiOiJtb2RlbCIsImNyZWF0ZWQiOjAsIm93bmVkX2J5Ijoib3BlbmFpIn1dLCJvYmplY3QiOiJsaXN0In0=
              status: 200
        key: "llm:admin:model-list"
        matches:
          - path:
              pathPrefix: /v1/models
          - path:
              pathPrefix: /models
        name: "admin:model-list"
        namespace: internal
      - backends:
          - backend: "/llm:model:gpt-5.4:0"
            weight: 1
        inlinePolicies:
          - ai:
              routes:
                "*": passthrough
                /v1/chat/completions: completions
                /v1/embeddings: embeddings
                /v1/images/edits: detect
                /v1/images/generations: detect
                /v1/images/variations: detect
                /v1/messages: messages
                /v1/responses: responses
                /v1/responses/compact: detect
                ":rawPredict": messages
                ":streamRawPredict": messages
        key: "llm:model:000000:gpt-5.4"
        matches:
          - headers:
              - name: x-gateway-model-name
                value:
                  exact: gpt-5.4
            path:
              pathPrefix: /
        name: "model:gpt-5.4"
        namespace: internal
listener_tcp_routes:
  - - llm
    - []
policies:
  - key: "llm:transformation"
    name:
      kind: Local
      name: "llm:transformation"
      namespace: internal
    target:
      gateway:
        gatewayName: name
        gatewayNamespace: ns
        listenerName: llm
    policy:
      traffic:
        phase: gateway
        transformation:
          request:
            set:
              - - x-gateway-model-name
                - "\nrequest.path.endsWith(\":streamRawPredict\") || request.path.endsWith(\":rawPredict\") ?\nrequest.path.regexReplace(\"^.*/publishers/anthropic/models/(.+?):.*\", \"${1}\") :\njson(request.body).model\n"
              - - anthropic-beta
                - "request.headers['anthropic-beta'].split(',').filter(v, v.trim() in [])"
          response: {}
backends:
  - backend:
      ai:
        name: "llm:model:gpt-5.4:0"
        namespace: ""
        target:
          providers:
            - active:
                gpt-5.4:
                  endpoint:
                    name: gpt-5.4
                    provider:
                      copilot:
                        model: gpt-5.4
                    hostOverride: ~
                    pathOverride: ~
                    pathPrefix: ~
                    tokenize: false
                  info:
                    health: 1
                    request_latency: 0
                    pending_requests: 0
                    total_requests: 0
                    consecutive_failures: 0
                    times_ejected: 0
                    evicted_until: ~
              rejected: {}
    inlinePolicies:
      - requestHeaderModifier:
          remove:
            - x-gateway-model-name
      - ai: {}
route_groups: []
workloads: []
services: []
