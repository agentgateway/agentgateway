---
source: crates/agentgateway/src/types/local_tests.rs
assertion_line: 152
description: "Config normalization test for inference_routing: YAML -> LocalConfig -> NormalizedLocalConfig -> YAML"
---
binds:
  - key: bind/3000
    address: "[::]:3000"
    protocol: http
    tunnelProtocol: direct
    listeners:
      ns/name/bind/3000/listener0:
        gatewayName: name
        gatewayNamespace: ns
        hostname: ""
        key: ns/name/bind/3000/listener0
        listenerName: listener0
        protocol: HTTP
listener_routes:
  - - ns/name/bind/3000/listener0
    - - backends:
          - inlinePolicies:
              - inferenceRouting:
                  target:
                    inlineBackend: "127.0.0.1:9002"
                  failureMode: failClosed
            service:
              name: default/my-model
              port: 8000
            weight: 1
        key: ns/name/bind/3000/listener0/default/standalone-epp
        matches:
          - path:
              pathPrefix: /v1/chat/completions
        name: standalone-epp
        namespace: default
listener_tcp_routes:
  - - ns/name/bind/3000/listener0
    - []
policies: []
backends: []
route_groups: []
workloads: []
services: []
