---
source: crates/llm/src/golden_tests.rs
description: src/tests/requests/responses/messages-rich.json
info:
  model: claude-sonnet-4-5
  store: false
  instructions: Return one inventory decision as JSON.
  input:
    - role: system
      content: Use the warehouse policy dated 2026-07-15.
    - role: developer
      content:
        - type: input_text
          text: Keep item IDs unchanged.
    - role: user
      content:
        - type: input_text
          text: Check item A-17 against these records.
        - type: input_image
          image_url: "https://example.com/a-17.webp"
          detail: auto
        - type: input_image
          image_url: "data:image/png;base64,aQ=="
        - type: input_file
          file_data: "data:application/pdf;base64,JVBERi0xLjQK"
          filename: policy.pdf
        - type: input_file
          file_data: "data:text/plain;base64,c2hlbGYgQjEy"
          filename: location.txt
    - role: assistant
      content: I will check the live record.
    - type: function_call
      id: fc_weather
      call_id: call_weather
      name: weather
      arguments: "{\"city\":\"Seattle\"}"
      status: completed
    - type: function_call_output
      call_id: call_weather
      output:
        - type: input_text
          text: "Rain, 12 C"
        - type: input_image
          image_url: "data:image/png;base64,aQ=="
      status: completed
    - type: custom_tool_call
      id: ctc_query
      call_id: call_query
      namespace: inventory
      name: lookup
      input: A-17
      status: completed
    - type: custom_tool_call_output
      call_id: call_query
      output:
        - type: input_file
          file_data: "data:text/plain;base64,aW4gc3RvY2s="
          filename: result.txt
  max_output_tokens: 512
  parallel_tool_calls: true
  text:
    format:
      type: json_schema
      name: inventory_decision
      strict: true
      schema:
        type: object
        properties:
          item_id:
            type: string
          available:
            type: boolean
        required:
          - item_id
          - available
        additionalProperties: false
  tools:
    - type: function
      name: weather
      description: Read current weather for a city.
      parameters:
        type: object
        properties:
          city:
            type: string
        required:
          - city
      strict: false
    - type: namespace
      name: inventory
      description: Warehouse inventory tools.
      tools:
        - type: function
          name: by_shelf
          parameters:
            type: object
        - type: custom
          name: lookup
          format:
            type: text
    - type: custom
      name: python
      description: Run a short Python expression.
      format:
        type: text
    - type: local_shell
    - type: shell
      environment:
        type: local
    - type: apply_patch
---
{
  "messages": [
    {
      "role": "user",
      "content": [
        {
          "type": "text",
          "text": "Check item A-17 against these records."
        },
        {
          "type": "image",
          "source": {
            "type": "url",
            "url": "https://example.com/a-17.webp"
          }
        },
        {
          "type": "image",
          "source": {
            "type": "base64",
            "media_type": "image/png",
            "data": "aQ=="
          }
        },
        {
          "type": "document",
          "source": {
            "type": "base64",
            "media_type": "application/pdf",
            "data": "JVBERi0xLjQK"
          },
          "title": "policy.pdf"
        },
        {
          "type": "document",
          "source": {
            "type": "text",
            "media_type": "text/plain",
            "data": "shelf B12"
          },
          "title": "location.txt"
        }
      ]
    },
    {
      "role": "assistant",
      "content": [
        {
          "type": "text",
          "text": "I will check the live record."
        },
        {
          "type": "tool_use",
          "id": "call_weather",
          "name": "weather",
          "input": {
            "city": "Seattle"
          }
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "tool_result",
          "tool_use_id": "call_weather",
          "content": [
            {
              "type": "text",
              "text": "Rain, 12 C"
            },
            {
              "type": "image",
              "source": {
                "type": "base64",
                "media_type": "image/png",
                "data": "aQ=="
              }
            }
          ]
        }
      ]
    },
    {
      "role": "assistant",
      "content": [
        {
          "type": "tool_use",
          "id": "call_query",
          "name": "agentgateway__responses__namespace_custom_2",
          "input": {
            "input": "A-17"
          }
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "tool_result",
          "tool_use_id": "call_query",
          "content": [
            {
              "type": "document",
              "source": {
                "type": "text",
                "media_type": "text/plain",
                "data": "in stock"
              },
              "title": "result.txt"
            }
          ]
        }
      ]
    }
  ],
  "system": [
    {
      "type": "text",
      "text": "Return one inventory decision as JSON."
    },
    {
      "type": "text",
      "text": "Use the warehouse policy dated 2026-07-15."
    },
    {
      "type": "text",
      "text": "Keep item IDs unchanged."
    }
  ],
  "model": "claude-sonnet-4-5",
  "max_tokens": 512,
  "tools": [
    {
      "name": "weather",
      "description": "Read current weather for a city.",
      "input_schema": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          }
        },
        "required": [
          "city"
        ]
      }
    },
    {
      "name": "agentgateway__responses__namespace_function_1",
      "description": "Responses tool inventory.by_shelf. Warehouse inventory tools.",
      "input_schema": {
        "type": "object",
        "properties": {
          "arguments": {
            "type": "object"
          }
        },
        "required": [
          "arguments"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "agentgateway__responses__namespace_custom_2",
      "description": "Responses tool inventory.lookup. Warehouse inventory tools.",
      "input_schema": {
        "type": "object",
        "properties": {
          "input": {
            "type": "string"
          }
        },
        "required": [
          "input"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "agentgateway__responses__custom_3",
      "description": "Responses tool python. Run a short Python expression.",
      "input_schema": {
        "type": "object",
        "properties": {
          "input": {
            "type": "string"
          }
        },
        "required": [
          "input"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "agentgateway__responses__local_shell_4",
      "description": "Execute one command on the client's local computer. Provide command as an argv array, env as string environment variables, and optional timeout_ms, user, and working_directory.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "object",
            "properties": {
              "command": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "timeout_ms": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "user": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "working_directory": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "command",
              "env"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "action"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "agentgateway__responses__shell_5",
      "description": "Execute one or more shell command strings in order on the client's local computer. Optional timeout_ms and max_output_length values limit total execution time and captured output.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "object",
            "properties": {
              "commands": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "timeout_ms": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "max_output_length": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              }
            },
            "required": [
              "commands"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "action"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "agentgateway__responses__apply_patch_6",
      "description": "Create, delete, or update one file in the client's local workspace. Create and update operations use path and diff. Delete operations use path.",
      "input_schema": {
        "type": "object",
        "properties": {
          "operation": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "type": {
                    "const": "create_file"
                  },
                  "path": {
                    "type": "string"
                  },
                  "diff": {
                    "type": "string"
                  }
                },
                "required": [
                  "type",
                  "path",
                  "diff"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "const": "delete_file"
                  },
                  "path": {
                    "type": "string"
                  }
                },
                "required": [
                  "type",
                  "path"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "const": "update_file"
                  },
                  "path": {
                    "type": "string"
                  },
                  "diff": {
                    "type": "string"
                  }
                },
                "required": [
                  "type",
                  "path",
                  "diff"
                ],
                "additionalProperties": false
              }
            ]
          }
        },
        "required": [
          "operation"
        ],
        "additionalProperties": false
      }
    }
  ],
  "output_config": {
    "format": {
      "type": "json_schema",
      "schema": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string"
          },
          "available": {
            "type": "boolean"
          }
        },
        "required": [
          "item_id",
          "available"
        ],
        "additionalProperties": false
      }
    }
  }
}
